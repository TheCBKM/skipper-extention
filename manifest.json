{
  "manifest_version": 3,
  "name": "__MSG_name__",
  "short_name": "__MSG_short_name__",
  "description": "__MSG_description__",
  "version": "2.0.2",
  "default_locale": "en",
  "homepage_url": "https://thecbkm.github.io/skipper-extention/",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://*.hotstar.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.de/*",
    "*://*.amazon.co.jp/*",
    "https://www.youtube.com/*",
    "https://youtube-skip-ads-please-oregon.onrender.com/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_icon": "icons/48.png",
    "default_popup": "ui/popup.html",
    "default_title": "__MSG_name__"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "options_page": "ui/options.html",
  "content_scripts": [
    {
      "matches": ["*://*.hotstar.com/*"],
      "js": ["content/bootstrap.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.de/*",
        "*://*.amazon.co.jp/*",
        "https://www.youtube.com/*"
      ],
      "js": ["content/bootstrap.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "core/*.js",
        "platforms/*/*.js",
        "platforms/*/*/*.js"
      ],
      "matches": [
        "*://*.hotstar.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.de/*",
        "*://*.amazon.co.jp/*",
        "https://www.youtube.com/*"
      ]
    }
  ]
}
