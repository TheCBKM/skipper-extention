{
  "manifest_version": 3,
  "name": "__MSG_name__",
  "description": "__MSG_description__",
  "version": "1.1.0",
  "default_locale": "en",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://*.hotstar.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.de/*",
    "*://*.amazon.co.jp/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": "icons/48.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://*.hotstar.com/*"],
      "js": ["content/hotstar.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.de/*",
        "*://*.amazon.co.jp/*"
      ],
      "js": [
        "content/prime/options.js",
        "content/prime/engine.js",
        "content/prime/amazon.min.js"
      ]
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube.js"]
    }
  ]
}
